<?xml version="1.0" encoding="UTF-8"?>
<definitions id="definitions"
  xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:fluxnova="http://fluxnova.finos.org/schema/1.0/bpmn"
  targetNamespace="Examples">

  <process id="regularSubProcessNotAdHoc" isExecutable="true">

    <startEvent id="start" />
    <sequenceFlow id="flow1" sourceRef="start" targetRef="subProcess" />

    <subProcess id="subProcess">
      <userTask id="taskA" name="Task A" />
      <startEvent id="subStart" />
      <sequenceFlow id="subFlow1" sourceRef="subStart" targetRef="taskA" />
      <sequenceFlow id="subFlow2" sourceRef="taskA" targetRef="subEnd" />
      <endEvent id="subEnd" />
    </subProcess>

    <sequenceFlow id="flow2" sourceRef="subProcess" targetRef="end" />
    <endEvent id="end" />

  </process>

</definitions>
