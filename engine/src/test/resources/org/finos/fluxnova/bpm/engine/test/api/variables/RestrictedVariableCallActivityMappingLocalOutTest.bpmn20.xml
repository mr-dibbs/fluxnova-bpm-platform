<?xml version="1.0" encoding="UTF-8"?>
<definitions
    xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
    targetNamespace="Examples">

  <process id="parentRestrictedIoMappingLocalOut" isExecutable="true">
    <startEvent id="start" />
    <sequenceFlow id="flow1" sourceRef="start" targetRef="callChild" />

    <callActivity id="callChild" calledElement="childRestrictedIoMapping">
      <extensionElements>
        <camunda:in sourceExpression="${secret}" target="subSecret" restricted="true" />
        <camunda:out sourceExpression="${subSecret}" target="resultSecret" readLocal="true" restricted="true" />
      </extensionElements>
    </callActivity>

    <sequenceFlow id="flow2" sourceRef="callChild" targetRef="parentWait" />
    <userTask id="parentWait" />
    <sequenceFlow id="flow3" sourceRef="parentWait" targetRef="end" />
    <endEvent id="end" />
  </process>

</definitions>
